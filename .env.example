# Supabase (public/anon key - safe for frontend)
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Chat backend URL
VITE_CHAT_API_URL="http://localhost:3001"

# Sentry Error Tracking (Frontend)
VITE_SENTRY_DSN="your-sentry-dsn-here"

# Telegram Integration (Backend only)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
TELEGRAM_ADMIN_CHAT_ID="your-telegram-chat-id-here"

# Supabase Service Role Key (Backend only - Critical for RLS bypass)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
